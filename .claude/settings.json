{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(*)",
      "mcp__context7__*",
      "mcp__github__*",
      "mcp__linear__*",
      "mcp__supabase__*",
      "mcp__infisical__*"
    ],
    "ask": [
      "mcp__infisical__create-secret",
      "mcp__infisical__update-secret",
      "mcp__infisical__delete-secret",
      "mcp__supabase__apply_migration",
      "mcp__supabase__deploy_edge_function",
      "Bash(npm publish:*)",
      "Bash(supabase db push:*)",
      "Bash(supabase functions deploy:*)",
      "Bash(supabase link:*)",
      "Bash(vercel deploy:*)",
      "Bash(vercel --prod:*)",
      "Bash(vercel env add:*)",
      "Bash(vercel env rm:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(supabase db reset:*)",
      "Bash(vercel rm:*)",
      "Read(.env*)",
      "Read(**/*.pem)"
    ]
  }
}
