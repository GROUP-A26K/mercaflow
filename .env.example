# Mercaflow — variables d'environnement.
# Copier en .env.local (jamais commité). Valeurs réelles gérées via Infisical.
# Source de vérité des variables : MEMORY.md.

# --- SEO (REQUIS) ---
# Sans cette variable, canonical/OG/sitemap retombent sur localhost en prod.
NEXT_PUBLIC_SITE_URL=https://mercaflow.ai

# --- Clerk (authentification) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Supabase (base de données uniquement — auth via JWT Clerk) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Resend (email transactionnel) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
